@page "/Visitantes"

<h3>Visitantes</h3>

<button class="btn btn-primary mb-3" @onclick="Nuevo">
    Nuevo Registro
</button>

<table class="table table-striped">

    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>TipoDocumento</th>
            <th>Documento</th>
            <th>Telefono</th>
            <th>FechaRegistro</th>

        </tr>
    </thead>

    <tbody>

        @foreach (var item in lista)
        {
            <tr>

                <td>@item.Id</td>
                <td>@item.Nombre</td>
                <td>@item.TipoDocumento</td>
                <td>@item.Documento</td>
                <td>@item.Telefono</td>
                <td>@item.FechaRegistro</td>

                <td>

                    <button class="btn btn-warning btn-sm"
                            @onclick="(()=>Editar(item))">
                        Editar
                    </button>

                    <button class="btn btn-danger btn-sm"
                            @onclick="(()=>Eliminar(item.Id))">
                        Eliminar
                    </button>

                </td>

            </tr>
        }

    </tbody>

</table>

@if (mostrarForm)
{

    <div class="card p-3 mt-3">

        <h5>@tituloFormulario</h5>

        <div class="mb-2">

            <label>Nombre</label>

            <input class="form-control"
                   @bind="modelo.Nombre" />

        </div>

        <div class="mb-2">

            <label>Estado</label>

            <select class="form-control"
                    @bind="modelo.Estado">

                <option>Activo</option>
                <option>Inactivo</option>

            </select>

        </div>

        <button class="btn btn-success"
                @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-secondary"
                @onclick="Cancelar">
            Cancelar
        </button>

    </div>

}

@code {

    List<ItemVM> lista = new();

    ItemVM modelo = new();

    bool mostrarForm = false;

    string tituloFormulario = "";

    protected override void OnInitialized()
    {

        lista.Add(new ItemVM { Id = 1, TipoDocumento=" cc", Documento="123", Nombre="diego", Telefono="344", FechaRegistro="2020-02-02"});
        lista.Add(new ItemVM { Id = 2, TipoDocumento = " ce", Documento = "456", Nombre = "maria", Telefono = "344", FechaRegistro = "2020-02-02" });
        lista.Add(new ItemVM { Id = 3, TipoDocumento = " pasaporte", Documento = "789", Nombre = "juan", Telefono = "344", FechaRegistro = "2020-02-02" });
        

    }

    void Nuevo()
    {
        modelo = new ItemVM();
        tituloFormulario = "Nuevo Registro";
        mostrarForm = true;
    }

    void Editar(ItemVM item)
    {
        modelo = new ItemVM
        {
            Id = item.Id,
            Nombre = item.Nombre,
            TipoDocumento = item.TipoDocumento,
            Documento = item.Documento,
            Telefono = item.Telefono,
            FechaRegistro = item.FechaRegistro
        };

        tituloFormulario = "Editar Registro";
        mostrarForm = true;
    }

    void Guardar()
    {

        if (modelo.Id == 0)
        {

            modelo.Id = lista.Count + 1;
            lista.Add(modelo);

        }
        else
        {

            var registro = lista.First(x => x.Id == modelo.Id);

            registro.Nombre = modelo.Nombre;
            registro.TipoDocumento = modelo.TipoDocumento;
            registro.Documento = modelo.Documento;
            registro.Telefono = modelo.Telefono;
            registro.FechaRegistro = modelo.FechaRegistro;

        }

        mostrarForm = false;

    }

    void Eliminar(int id)
    {

        var registro = lista.First(x => x.Id == id);

        lista.Remove(registro);

    }

    void Cancelar()
    {
        mostrarForm = false;
    }

    public class ItemVM
    {
        public int Id { get; set; }

        public string Nombre { get; set; }

        public string TipoDocumento { get; set; }
        public string Documento { get; set; }
        public string Telefono { get; set; }
        public string FechaRegistro { get; set; }
    }

}